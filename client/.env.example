# ─── Required (set in Vercel environment variables) ──────────────────────────
VITE_API_URL=https://your-app.up.railway.app   # Railway backend URL (no trailing slash)

# ─── Optional ─────────────────────────────────────────────────────────────────
# Set this to the same value as the server's ADMIN_SECRET env var.
# Used by the "Refresh Image" button on item detail pages to call
# POST /api/admin/refresh-image/:catalog_id without needing a separate tool.
# For local dev, add to client/.env.local (never commit that file).
VITE_ADMIN_SECRET=
