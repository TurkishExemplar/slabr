# ─── Required ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/slabr
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-characters

# ─── Optional ───────────────────────────────────────────────────────────────
PORT=3001                              # Backend port (default 3001)
CLIENT_URL=http://localhost:3000       # CORS allowed origin

# ─── Phase 5 (Claude Vision scan-to-add) ────────────────────────────────────
ANTHROPIC_API_KEY=                    # From console.anthropic.com — used for card/slab identification

# ─── Phase 8 (eBay market data) ─────────────────────────────────────────────
EBAY_APP_ID=                           # eBay Developer Program Client ID (App ID)
EBAY_CERT_ID=                          # eBay Developer Program Client Secret (Cert ID) — required for OAuth
EBAY_ENV=production                    # 'production' or 'sandbox'
